// prisma/schema.prisma — Koogwe Backend v3.2 (Face Verification)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  SUPPORT
  READONLY
}

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REFUNDED
}

enum PromoDiscountType {
  PERCENT
  FIXED
}

enum AccountStatus {
  EMAIL_NOT_VERIFIED
  EMAIL_VERIFIED
  FACE_VERIFICATION_PENDING
  DOCUMENTS_PENDING
  ADMIN_REVIEW_PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum FaceVerificationMethod {
  SELFIE_ONLY
  SELFIE_WITH_ID
  BASIC_LIVENESS
}

enum RideStatus {
  REQUESTED
  ACCEPTED
  DRIVER_EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
  ORANGE_MONEY
  FREE_MONEY
  WAVE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum VehicleType {
  MOTO
  ECO
  CONFORT
  VAN
  BERLINE
  SUV
  LUXE
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum NotificationType {
  RIDE_REQUEST
  RIDE_ACCEPTED
  RIDE_CANCELLED
  DRIVER_ARRIVED
  RIDE_COMPLETED
  PAYMENT_RECEIVED
  ACCOUNT_VALIDATED
  NEW_MESSAGE
  PROMO
  ADMIN_ACTION
  PANIC
  FAVORITE_DRIVER
}

enum DocumentType {
  ID_CARD_FRONT
  ID_CARD_BACK
  PASSPORT
  SELFIE
  SELFIE_WITH_ID
  DRIVERS_LICENSE
  VEHICLE_REGISTRATION
  INSURANCE
  TECHNICAL_CONTROL
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  RECHARGE
  PAYMENT
  REFUND
  WITHDRAWAL
  COMMISSION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum ServiceType {
  VTC
  DELIVERY
}

enum ParcelSize {
  SMALL
  MEDIUM
  LARGE
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  hashedPassword     String?
  phone              String?  @unique
  firstName          String?
  lastName           String?
  avatarUrl          String?
  role               UserRole @default(PASSENGER)
  adminRole          AdminRole?
  isVerified         Boolean  @default(false)
  isActive           Boolean  @default(true)
  language           String   @default("fr")
  fcmToken           String?
  stripeCustomerId   String?  @unique
  paypalEmail        String?
  notifPushEnabled   Boolean  @default(true)
  notifEmailEnabled  Boolean  @default(true)
  accountStatus      AccountStatus @default(EMAIL_NOT_VERIFIED)

  otpCode            String?
  otpExpiresAt       DateTime?
  otpAttempts        Int      @default(0)
  refreshToken       String?

  faceVerified       Boolean  @default(false)
  faceImageUrl       String?
  faceVerifiedAt     DateTime?
  faceVerificationMethod FaceVerificationMethod?
  faceConfidenceScore Float?
  faceVerificationAttempts Int @default(0)
  lastFaceVerificationAttempt DateTime?
  lastLoginAt        DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  driverProfile      DriverProfile?
  passengerRides     Ride[]   @relation("PassengerRides")
  driverRides        Ride[]   @relation("DriverRides")
  sentMessages       Message[] @relation("SentMessages")
  notifications      Notification[]
  reviewsGiven       Review[] @relation("ReviewsGiven")
  reviewsReceived    Review[] @relation("ReviewsReceived")
  payments           Payment[]
  wallet             Wallet?
  transactions       Transaction[]
  documents          Document[]
  savedPlaces        SavedPlace[]
  savedCards         SavedCard[]
  auditLogs          AuditLog[]     @relation("AdminAuditLogs")
  disputesReported   Dispute[]      @relation("DisputeReporter")
  disputesResolved   Dispute[]      @relation("DisputeResolver")

  @@map("users")
}

model SavedCard {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeMethodId  String   @unique
  brand           String?
  last4           String?
  expMonth        Int?
  expYear         Int?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("saved_cards")
}

model DriverProfile {
  id                      String      @id @default(uuid())
  userId                  String      @unique
  user                    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  vehicleType             VehicleType @default(MOTO)
  vehicleMake             String?
  vehicleModel            String?
  vehicleYear             Int?
  licensePlate            String?
  vehicleColor            String?

  faceVerified            Boolean     @default(false)
  faceVerifiedAt          DateTime?
  faceVerificationMethod  FaceVerificationMethod?

  documentsUploaded       Boolean     @default(false)
  documentsUploadedAt     DateTime?

  adminApproved           Boolean     @default(false)
  adminApprovedAt         DateTime?
  adminNotes              String?

  isOnline                Boolean     @default(false)
  currentLat              Float?
  currentLng              Float?
  heading                 Float?
  lastLocationAt          DateTime?

  totalRides              Int         @default(0)
  totalEarnings           Float       @default(0)
  rating                  Float       @default(0)
  ratingCount             Int         @default(0)

  bankAccountHolder       String?
  bankIban                String?
  bankBic                 String?

  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@index([isOnline, currentLat, currentLng])
  @@map("driver_profiles")
}

model Document {
  id              String         @id @default(uuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            DocumentType
  fileUrl         String
  publicId        String?

  status          DocumentStatus @default(PENDING)
  rejectionReason String?

  uploadedAt      DateTime       @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?

  @@index([status, uploadedAt])
  @@index([userId])
  @@map("documents")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Float    @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallets")
}

model Transaction {
  id              String            @id @default(uuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  type            TransactionType
  amount          Float
  status          TransactionStatus @default(PENDING)
  rideId          String?
  paymentMethod   PaymentMethod?
  externalRef     String?
  reference       String?
  rejectionReason String?
  createdAt       DateTime          @default(now())
  completedAt     DateTime?

  @@index([userId, createdAt])
  @@map("transactions")
}

model Ride {
  id                String      @id @default(uuid())
  serviceType       ServiceType @default(VTC)
  passengerId       String
  passenger         User        @relation("PassengerRides", fields: [passengerId], references: [id])
  driverId          String?
  driver            User?       @relation("DriverRides", fields: [driverId], references: [id])

  pickupAddress     String?
  pickupLat         Float
  pickupLng         Float
  dropoffAddress    String?
  dropoffLat        Float
  dropoffLng        Float
  waypoints         Json?

  airConditioning   Boolean     @default(false)
  wifi              Boolean     @default(false)
  usb               Boolean     @default(false)
  music             Boolean     @default(false)

  status            RideStatus  @default(REQUESTED)
  vehicleType       VehicleType @default(MOTO)
  estimatedPrice    Float
  finalPrice        Float?
  distanceKm        Float?
  durationMin       Int?
  pinCode           String
  pinAttempts       Int           @default(0)

  paymentMethod     PaymentMethod @default(CASH)
  isPaid            Boolean       @default(false)
  tipAmount         Float?
  payment           Payment?

  scheduledAt       DateTime?
  shareToken        String?       @unique

  senderName        String?
  senderPhone       String?
  recipientName     String?
  recipientPhone    String?
  parcelSize        ParcelSize?
  parcelDesc        String?
  deliveryNote      String?

  requestedAt       DateTime    @default(now())
  acceptedAt        DateTime?
  arrivedAt         DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?

  passengerRating   Float?
  driverRating      Float?
  passengerComment  String?
  driverComment     String?

  messages          Message[]
  reviews           Review[]
  disputes          Dispute[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([passengerId, requestedAt])
  @@index([driverId, requestedAt])
  @@index([status])
  @@map("rides")
}

model Payment {
  id            String        @id @default(uuid())
  rideId        String        @unique
  ride          Ride          @relation(fields: [rideId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  amount        Float
  currency      String        @default("EUR")
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  externalRef   String?
  failureReason String?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Message {
  id        String      @id @default(uuid())
  rideId    String
  ride      Ride        @relation(fields: [rideId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User        @relation("SentMessages", fields: [senderId], references: [id])
  content   String
  type      MessageType @default(TEXT)
  isRead    Boolean     @default(false)
  readAt    DateTime?
  createdAt DateTime    @default(now())

  @@map("messages")
}

model Review {
  id          String   @id @default(uuid())
  rideId      String
  ride        Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("ReviewsGiven", fields: [authorId], references: [id])
  targetId    String
  target      User     @relation("ReviewsReceived", fields: [targetId], references: [id])
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([rideId, authorId])
  @@map("reviews")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model SavedPlace {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  address   String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("saved_places")
}

/// Configuration globale (singleton id = "default")
model PlatformSettings {
  id         String   @id @default("default")
  pricing    Json     @default("{}")
  financials Json     @default("{}")
  payments   Json     @default("{}")
  security   Json     @default("{}")
  platform   Json     @default("{}")
  emails     Json     @default("{}")
  updatedAt  DateTime @updatedAt

  @@map("platform_settings")
}

/// Zones à forte demande (surge / visibilité)
model HotZone {
  id              String   @id @default(uuid())
  name            String
  centerLat       Float
  centerLng       Float
  radiusKm        Float    @default(2)
  surgeMultiplier Float    @default(1.2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@map("hot_zones")
}

model AuditLog {
  id           String   @id @default(uuid())
  adminId      String?
  admin        User?    @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: SetNull)
  adminEmail   String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ip           String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

model Dispute {
  id           String        @id @default(uuid())
  rideId       String?
  ride         Ride?         @relation(fields: [rideId], references: [id], onDelete: SetNull)
  reporterId   String?
  reporter     User?         @relation("DisputeReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  reason       String
  status       DisputeStatus @default(OPEN)
  adminNotes   String?
  refundAmount Float?
  rating       Int?
  resolvedById String?
  resolvedBy   User?         @relation("DisputeResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("disputes")
}

model PromoCode {
  id            String            @id @default(uuid())
  code          String            @unique
  label         String?
  discountType  PromoDiscountType @default(PERCENT)
  discountValue Float
  maxUses       Int?
  usedCount     Int               @default(0)
  validFrom     DateTime?
  validUntil    DateTime?
  targetRole    UserRole?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([isActive])
  @@map("promo_codes")
}

model FaqEntry {
  id         String   @id @default(uuid())
  questionFr String
  questionEn String?
  answerFr   String
  answerEn   String?
  category   String   @default("general")
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("faq_entries")
}