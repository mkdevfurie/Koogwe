# Base de données
DATABASE_URL=postgresql://user:password@host:5432/koogwe?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/koogwe?sslmode=require

# JWT (générer des secrets forts en production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Serveur
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3000
FRONTEND_URLS=

# Admin (obligatoire en production pour le premier compte)
ADMIN_EMAIL=admin@koogwe.com
ADMIN_PASSWORD=

# Email
RESEND_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (obligatoire en production)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_ENABLED=false

# Firebase Cloud Messaging (JSON complet du compte de service, une ligne)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Tarification
PRICING_PICKUP_FEE=3
PRICING_KM_MOTO=1.0
PRICING_KM_ECO=1.2
PRICING_KM_CONFORT=1.5
PRICING_KM_VAN=1.9
PRICING_KM_LUXE=2.5
PRICING_MINUTE_RATE=0.30
PRICING_MIN_PRICE=7
PLATFORM_COMMISSION_RATE=0.2
# Fallback si non défini dans le dashboard admin (Paramètres → Plateforme)
DRIVER_SEARCH_RADIUS_KM=30

# OTP
OTP_MAX_ATTEMPTS=5

# AWS Rekognition (optionnel)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
